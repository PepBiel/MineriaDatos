weight_diff <- weight - weight_mean
time_diff <- time - time_mean
# Covariance calc
covariance <- sum(weight_diff * time_diff) / (length(weight) - 1)
# Result
cat("Covariance between weight and time:", covariance, "\n")
# Dataset ChickWeight ya cargado
peso <- ChickWeight$weight
tiempo <- ChickWeight$Time
# Obtener los días únicos
dias_unicos <- unique(tiempo)
# Inicializar listas para almacenar resultados
medias_por_dia <- numeric(length(dias_unicos))
varianzas_por_dia <- numeric(length(dias_unicos))
# Iterar sobre cada día y calcular la media y varianza del peso
for (i in seq_along(dias_unicos)) {
dia <- dias_unicos[i]
# Filtrar los datos para el día actual
pesos_en_dia <- peso[tiempo == dia]
# Calcular la media manualmente
media_dia <- sum(pesos_en_dia) / length(pesos_en_dia)
medias_por_dia[i] <- media_dia
# Calcular la varianza manualmente
varianza_dia <- sum((pesos_en_dia - media_dia)^2) / (length(pesos_en_dia) - 1)
varianzas_por_dia[i] <- varianza_dia
}
# Mostrar los resultados
resultados <- data.frame(
Dia = dias_unicos,
Media_Peso = medias_por_dia,
Varianza_Peso = varianzas_por_dia
)
print(resultados)
